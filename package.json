{
  "name": "@opendevsdk/opendevsdk",
  "private": true,
  "publishConfig": {
    "access": "restricted"
  },
  "scripts": {
    "build": "turbo run build",
    "build:force": "turbo run build --force",
    "check": "turbo run check",
    "provision": "node scripts/provision-origins.mjs",
    "validate:packages": "node scripts/provision-origins.mjs --validate-only"
  },
  "packageManager": "pnpm@10.31.0",
  "devDependencies": {
    "turbo": "2.8.20",
    "dotenv": "17.3.1"
  }
}
