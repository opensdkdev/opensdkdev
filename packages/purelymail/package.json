{
  "name": "@opendevsdk/purelymail",
  "version": "0.0.1",
  "private": true,
  "publishConfig": {
    "access": "restricted"
  },
  "scripts": {
    "provision": "node ../../scripts/provision.mjs --package-dir .",
    "release": "fern generate --group typescript",
    "definition": "fern write-definition",
    "check": "fern check",
    "ci:release": "pnpm provision && pnpm check && pnpm definition && pnpm release --force"
  },
  "packageManager": "pnpm@10.31.0",
  "devDependencies": {
    "fern-api": "4.26.0"
  }
}
